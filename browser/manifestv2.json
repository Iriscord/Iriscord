{
    "manifest_version": 2,
    "minimum_chrome_version": "91",

    "name": "Iriscord",
    "description": "A modern Discord client mod — powered by Iris",
    "author": "Iriscord Contributors",
    "homepage_url": "https://github.com/iriscord/iriscord",
    "icons": {
        "128": "icon.png"
    },

    "permissions": [
        "webRequest",
        "webRequestBlocking",
        "*://*.discord.com/*",
        "https://raw.githubusercontent.com/*"
    ],

    "content_scripts": [
        {
            "run_at": "document_start",
            "matches": ["*://*.discord.com/*"],
            "js": ["content.js"],
            "all_frames": true,
            "world": "ISOLATED"
        },
        {
            "run_at": "document_start",
            "matches": ["*://*.discord.com/*"],
            "js": ["dist/Iriscord.js"],
            "all_frames": true,
            "world": "MAIN"
        }
    ],

    "background": {
        "scripts": ["background.js"]
    },

    "web_accessible_resources": ["dist/Iriscord.js", "dist/Iriscord.css"],

    "browser_specific_settings": {
        "gecko": {
            "id": "iriscord@iriscord.dev",
            "strict_min_version": "128.0"
        }
    }
}
